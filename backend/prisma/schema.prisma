generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Vault {
  id                  Int                  @id @default(autoincrement())
  tokenMint           String               @unique
  creator             String
  feeAccount          String
  vaultPool           String
  name                String?
  symbol              String?
  metadataUri         String?
  imageUrl            String?
  bondingCurve        String?
  feeSharingConfirmed Boolean              @default(false)
  vaultCreated        Boolean              @default(false)
  retryCount          Int                  @default(0)
  lastRetryAt         DateTime?
  confirmedAt         DateTime?
  active              Boolean              @default(true)
  consecutiveFailures Int                  @default(0)
  lastErrorType       String?
  pausedAt            DateTime?
  pauseReason         String?
  createdAt           DateTime             @default(now())

  // LP Automation + Platform Fees
  maxHolders          Int                  @default(100)     // 100-512, max holders per distribution
  holderSplitBps      Int                  @default(5000)    // 0-10000, creator's chosen holder/LP split
  platformFeeBps      Int                  @default(500)     // snapshot at launch (500 = 5%)
  graduated           Boolean              @default(false)
  graduatedAt         DateTime?
  lpDeployed          Boolean              @default(false)
  lpPoolKey           String?                                // PumpSwap pool pubkey
  lpSolDeposited      BigInt               @default(0)       // cumulative SOL into LP (lamports)
  pendingLpSol        BigInt               @default(0)       // SOL waiting for LP threshold
  lpTokenBalance      BigInt               @default(0)       // LP tokens held
  lpDepositedValue    BigInt               @default(0)       // SOL value at deposit time (profit calc)
  totalPlatformFees   BigInt               @default(0)       // cumulative platform fees tracked
  lastSweepAt         DateTime?

  // Buyback
  buybackEnabled        Boolean              @default(false)
  buybackSplitBps       Int                  @default(0)       // 0-10000, fraction of post-platform fees to buyback
  buybackAction         String               @default("hold")  // "hold" | "burn"
  buybackThresholdSol   BigInt               @default(100000000) // min lamports before executing (0.1 SOL)
  pendingBuybackSol     BigInt               @default(0)       // SOL accumulated for next buyback
  totalBuybackSol       BigInt               @default(0)       // cumulative SOL spent on buybacks
  buybackTokenBalance   BigInt               @default(0)       // tokens held (if action=hold)

  // Time-locked split changes
  pendingSplitBps     Int?
  splitProposedAt     DateTime?
  splitEffectiveAt    DateTime?

  // Claim expiry
  claimExpiryHours      Int?                                   // null = DEFAULT_CLAIM_EXPIRY_HOURS (168)
  expiredUnclaimedTotal BigInt               @default(0)       // cumulative expired lamports

  // Vault closure
  closeRequestedAt    DateTime?

  // Push model
  distributionMode       String              @default("push")  // "pull" or "push"
  lastDistributionAt     DateTime?
  totalOutstandingPush   BigInt              @default(0)        // carry-forward SOL not yet pushed

  holders             HolderBalance[]
  distributions       DistributionRecord[]
  lpOperations        LpOperation[]
  expiredAllocations  ExpiredAllocation[]
}

model HolderBalance {
  id               Int       @id @default(autoincrement())
  vaultId          Int
  wallet           String
  balance          BigInt
  holdingSince     DateTime
  lastUpdated      DateTime
  balanceZeroSince DateTime?              // set when balance transitions >0 -> 0, null when >0
  totalReceived    BigInt    @default(0)  // cumulative SOL pushed to this holder
  vault            Vault     @relation(fields: [vaultId], references: [id])

  @@unique([vaultId, wallet])
}

model DistributionRecord {
  id             Int                @id @default(autoincrement())
  vaultId        Int
  epochNumber    Int
  merkleRoot     String
  totalAllocated BigInt
  holderCount    Int
  txSignature    String?
  createdAt      DateTime           @default(now())
  pushCompleted  Boolean            @default(false)
  totalPushed    BigInt             @default(0)
  pushBatchCount Int                @default(0)
  vault          Vault              @relation(fields: [vaultId], references: [id])
  allocations    AllocationRecord[]
  pushRecords    PushRecord[]

  @@unique([vaultId, epochNumber])
}

model AllocationRecord {
  id               Int                @id @default(autoincrement())
  distributionId   Int
  wallet           String
  cumulativeAmount BigInt
  score            Float
  proof            String
  distribution     DistributionRecord @relation(fields: [distributionId], references: [id])

  @@unique([distributionId, wallet])
}

model LpOperation {
  id            Int      @id @default(autoincrement())
  vaultId       Int
  type          String   // "DEPLOY" | "HARVEST" | "COMPOUND" | "BUYBACK"
  solAmount     BigInt   // lamports involved
  lpTokens      BigInt   @default(0)  // LP tokens minted or burned
  txSignatures  String[] // all TX sigs for the multi-step operation
  status        String   // "SUCCESS" | "PARTIAL" | "FAILED"
  error         String?  // error message if failed
  createdAt     DateTime @default(now())
  vault         Vault    @relation(fields: [vaultId], references: [id])

  @@index([vaultId, createdAt])
}

model ExpiredAllocation {
  id               Int      @id @default(autoincrement())
  vaultId          Int
  wallet           String
  cumulativeAmount BigInt
  claimedAmount    BigInt
  expiredAmount    BigInt
  expiredAt        DateTime @default(now())

  vault Vault @relation(fields: [vaultId], references: [id])
  @@unique([vaultId, wallet])
  @@index([vaultId])
}

model PushRecord {
  id               Int      @id @default(autoincrement())
  distributionId   Int
  wallet           String
  amount           BigInt
  batchIndex       Int
  batchTxSig       String?  // null while pending, set after TX confirms
  status           String   @default("pending") // "pending" | "confirmed" | "failed"
  pushedAt         DateTime @default(now())

  distribution     DistributionRecord @relation(fields: [distributionId], references: [id])

  @@unique([distributionId, wallet])
  @@index([distributionId])
  @@index([wallet])
}

model VanityKeypair {
  id               Int       @id @default(autoincrement())
  publicKey        String    @unique              // base58 pubkey (= mint address)
  encryptedKey     String                         // AES-256-GCM encrypted 64-byte secret key
  suffix           String                         // vanity suffix matched (e.g. "anvi1")
  claimed          Boolean   @default(false)      // true = handed out to a /build-tx call
  confirmedOnChain Boolean   @default(false)      // true = token creation confirmed on-chain
  claimedAt        DateTime?                      // when claimed by /build-tx
  createdAt        DateTime  @default(now())

  @@index([claimed, suffix])
}

// ─── Custodial Wallet System ────────────────────────────────────────────────

model BotWallet {
  id              String      @id @default(cuid())
  xUserId         String      @unique         // Twitter user ID (immutable)
  xUsername        String                      // @handle (cached, may change)
  publicKey       String      @unique         // Base58 wallet address
  encryptedKey    String                      // AES-256-GCM iv:authTag:ciphertext
  keyVersion      Int         @default(1)     // For future master key rotation

  defaultSplitBps     Int     @default(5000)
  defaultMaxHolders   Int     @default(100)
  defaultDevBuySol    Float   @default(0)
  defaultExpiryHours  Int     @default(168)

  launchesToday   Int         @default(0)
  lastLaunchDate  DateTime?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  launches        BotLaunch[]
}

model BotLaunch {
  id              String      @id @default(cuid())
  walletId        String
  wallet          BotWallet   @relation(fields: [walletId], references: [id])

  source          String      @default("twitter")  // "twitter" | "platform"
  tweetId         String?     @unique              // Only for twitter launches
  replyTweetId    String?

  tokenName       String
  tokenSymbol     String
  tokenMint       String?
  devBuySol       Float       @default(0)
  maxHolders      Int         @default(100)
  holderSplitBps  Int         @default(5000)
  claimExpiryHours Int        @default(168)

  status          String      @default("parsing")
  errorMessage    String?
  txSignature     String?
  configureTxSig  String?

  createdAt       DateTime    @default(now())
  completedAt     DateTime?

  @@index([status])
  @@index([walletId])
}

model BotConfig {
  id              String      @id @default("singleton")
  sinceId         String?
  updatedAt       DateTime    @updatedAt
}
